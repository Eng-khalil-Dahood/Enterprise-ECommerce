@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">📊 لوحة التحكم بالإحصائيات الحية</h2>
    
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 shadow">
                <h5>إجمالي المبيعات</h5>
                <h3 id="totalSales">$0</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 shadow">
                <h5>عدد الطلبات الكلي</h5>
                <h3 id="totalOrders">0</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-3 shadow">
                <h5>منتجات شارف مخزونها على الانتهاء</h5>
                <h3 id="lowStock">0</h3>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card p-4 shadow">
                <h5 class="card-title">📈 المنتجات الأكثر مبيعاً</h5>
                <canvas id="salesChart" width="400" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // كود جافا سكريبت للاتصال بالخلفية البرمجية وعرض البيانات فوراً
    async function loadDashboardData() {
        try {
            // جلب البيانات من الـ API (تأكد من تعديل الـ Port ليتناسب مع مشروع الـ API لديك عند التشغيل)
            const response = await fetch('http://localhost:5000/api/dashboard/stats'); 
            const data = await response.json();

            // توزيع الأرقام على الشاشة
            document.getElementById('totalSales').innerText = '$' + data.totalSales;
            document.getElementById('totalOrders').innerText = data.totalOrders;
            document.getElementById('lowStock').innerText = data.lowStockProducts;

            // رسم المخطط البياني التفاعلي
            const ctx = document.getElementById('salesChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.topProductNames,
                    datasets: [{
                        label: 'عدد المبيعات',
                        data: data.topProductSalesCount,
                        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545'],
                        borderWidth: 1
                    }]
                },
                options: {
                    scales: { y: { beginAtZero: true } }
                }
            });
        } catch (error) {
            console.error("خطأ في جلب بيانات الإحصائيات:", error);
        }
    }

    // تشغيل الدالة تلقائياً عند فتح الصفحة
    window.onload = loadDashboardData;
</script>